{
  "name": "@relay/web-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev -w @relay/api",
    "dev:browser": "npm run dev -w @relay/browser",
    "dev:client": "npm run dev -w @relay/client",
    "dev:worker": "npm run dev -w @relay/worker",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
